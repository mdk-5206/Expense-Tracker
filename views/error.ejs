<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Error <%= locals.status || 500 %></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="bg-light">
    <div class="container py-5">
        <div class="card shadow-sm mx-auto" style="max-width: 600px;">
            <div class="card-body text-center">
                <h1 class="display-1 text-danger"><%= locals.status || 500 %></h1>
                <h2 class="h4 mb-4">Oops! Something went wrong.</h2>
                <p class="text-muted"><%= locals.message %></p>
                
                <% if (locals.stack) { %>
                    <div class="text-start mt-4">
                        <pre class="bg-dark text-white p-3 rounded small"><code><%= stack %></code></pre>
                    </div>
                <% } %>
                
                <a href="/" class="btn btn-primary mt-3">Return to Dashboard</a>
            </div>
        </div>
    </div>
</body>
</html>