<div class="row justify-content-center mt-5">
    <div class="col-md-5">
        <div class="card shadow">
            <div class="card-body">
                <h2 class="text-center mb-4">Login</h2>

                <% if (locals.error) { %>
                    <div class="alert alert-danger"><%= error %></div>
                <% } %>

                <form action="/auth/login" method="POST" autocomplete="off">
                    <div class="mb-3">
                        <label class="form-label">Email</label>
                        <input type="email" name="email" class="form-control" required placeholder="email@example.com" autocomplete="off">
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Password</label>
                        <input type="password" name="password" class="form-control" required placeholder="••••" autocomplete="new-password">
                    </div>
                    <div class="d-grid gap-2">
                        <button type="submit" class="btn btn-primary">Login</button>
                    </div>
                </form>

                <div class="mt-4 text-center">
                    <p class="text-muted">Don't have an account? <a href="/auth/register" class="text-decoration-none">Register</a></p>
                </div>
            </div>
        </div>
    </div>
</div>